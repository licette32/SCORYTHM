# ─── Scorythm Agent — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Stellar Testnet ──────────────────────────────────────────────────────────
# Your Stellar testnet keypair.
# Generate one at: https://laboratory.stellar.org/#account-creator?network=test
# or with: stellar keys generate --network testnet mykey
STELLAR_ADDRESS=GBXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STELLAR_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Service URLs ─────────────────────────────────────────────────────────────
# URL of the x402 signal server (Node.js / Express)
SERVER_URL=http://localhost:3000

# URL of the FastAPI agent API
API_URL=http://localhost:8000

# ─── x402 Facilitator ────────────────────────────────────────────────────────
# The x402 payment facilitator endpoint.
# Default points to the public testnet facilitator.
FACILITATOR_URL=https://x402.org/facilitator

# ─── Optional: Server port override ──────────────────────────────────────────
PORT=3000

# ─── Claude (Anthropic) — for decision explanations ──────────────────────────
# Get your API key at: https://console.anthropic.com/
# If not set, the agent works without explanations (no error shown)
ANTHROPIC_API_KEY=sk-ant-...


# ─── IPQualityScore — Real IP reputation API ──────────────────────────────────
IPQS_API_KEY=xEnc......